{
  "name": "shader-graph-glsl",
  "version": "0.1.0",
  "private": true,
  "description": "shader graph for GLSL (WebGL2 / renderer-agnostic) — monorepo",
  "scripts": {
    "dev": "vite",
    "dev:docs": "pnpm --filter @shader-graph-glsl/docs dev",
    "build": "tsc && vite build",
    "build:editor": "vite build --config vite.config.editor.ts && pnpm -s exec node -e \"require('fs').renameSync('apps/docs/public/editor/editor.html','apps/docs/public/editor/index.html')\"",
    "build:docs": "pnpm build:editor && pnpm --filter @shader-graph-glsl/docs build",
    "preview": "vite preview",
    "preview:docs": "pnpm --filter @shader-graph-glsl/docs preview"
  },
  "keywords": [
    "node material",
    "shader graph",
    "glsl",
    "webgl2"
  ],
  "author": "deepkolos@qq.com",
  "dependencies": {
    "@codemirror/commands": "^6.3.3",
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/language": "^6.10.1",
    "@codemirror/lint": "^6.4.2",
    "@codemirror/state": "^6.0.1",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@codemirror/view": "^6.25.1",
    "codemirror": "^6.0.1",
    "copy-to-clipboard": "3.3.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rete-area-plugin": "^0.2.1",
    "three": "^0.151.3",
    "use-debounce": "^9.0.4"
  },
  "devDependencies": {
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/three": "^0.150.2",
    "@vitejs/plugin-react": "^3.1.0",
    "less": "^4.1.3",
    "typescript": "^4.9.3",
    "vite": "^4.5.2"
  },
  "license": "MIT"
}
